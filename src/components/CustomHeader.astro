---
import SiteTitle from 'virtual:starlight/components/SiteTitle';
import Search from 'virtual:starlight/components/Search';
import SocialIcons from 'virtual:starlight/components/SocialIcons';
import ThemeSelect from 'virtual:starlight/components/ThemeSelect';
import LanguageSelect from 'virtual:starlight/components/LanguageSelect';
---

<div class="header sl-flex">
  <div class="title-wrapper sl-flex">
    <SiteTitle />
  </div>
  <nav class="nav-links sl-flex print:hidden">
    <a href="https://www.usframeteam.top/" class="nav-link">USF首页</a>
    <a href="https://docs.usframeteam.top/" class="nav-link" target="_blank" rel="noopener noreferrer">
      正式站
    </a>
  </nav>
  <div class="sl-flex print:hidden search-wrapper">
    <Search />
  </div>
  <div class="sl-flex print:hidden right-group">
    <div class="sl-flex social-icons">
      <SocialIcons />
    </div>
    <div class="theme-select-wrapper">
      <ThemeSelect />
    </div>
    <LanguageSelect />
  </div>
</div>

<style>
  .header {
    display: flex;
    gap: var(--sl-nav-gap);
    justify-content: space-between;
    align-items: center;
    height: 100%;
    width: 100%;
  }
  .title-wrapper {
    overflow: clip;
    padding: 0.25rem;
    margin: -0.25rem;
    min-width: 0;
    flex-shrink: 0;
  }
  .nav-links {
    gap: 1rem;
    align-items: center;
    flex-shrink: 0;
  }
  .nav-link {
    color: var(--sl-color-text);
    text-decoration: none;
    font-size: var(--sl-text-sm);
    font-weight: 500;
    padding: 0.25rem 0;
    border-bottom: 2px solid transparent;
    transition: color 0.2s, border-color 0.2s;
    white-space: nowrap;
  }
  .nav-link:hover {
    color: var(--sl-color-text-accent);
  }
  .search-wrapper {
    flex: 1;
    justify-content: center;
    min-width: 0;
  }
  .right-group {
    gap: 1rem;
    align-items: center;
    flex-shrink: 0;
  }
  .social-icons {
    gap: 1rem;
    align-items: center;
  }
  .social-icons::after {
    content: '';
    height: 2rem;
    border-inline-end: 1px solid var(--sl-color-gray-5);
  }

  @media (max-width: 50rem) {
    .nav-links {
      display: none;
    }
    .social-icons {
      display: none;
    }
    .theme-select-wrapper {
      display: none;
    }
  }
</style>
